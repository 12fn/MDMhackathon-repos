# DDE-RAG — Distributed Data Engine RAG demo
# Defaults run against OPENAI_API_KEY at the repo root .env.

# Multi-node DDE config (comma-separated host:port pairs, in node order:
#   albany,lejeune,quantico). When set, the app reports these endpoints in the
#   "compute-at-data" beat.
KAMIWAZA_DDE_NODES=albany.gcssmc.usmc.mil:8443,lejeune.icm.usmc.mil:8443,quantico.tm.usmc.mil:8443

# Swap the active provider to your Kamiwaza control plane (OpenAI-compat surface)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=...

# Per-node bandwidth class (informational; drives the comparison chart)
DDE_NODE_BANDWIDTH_MBPS=albany:50,lejeune:25,quantico:100
