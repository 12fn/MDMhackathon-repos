# ANCHOR — provider config (auto-detected by shared/kamiwaza_client.py).
# Pick ONE provider; see ../DEPLOY.md for full matrix.

# ── Kamiwaza on-prem (recommended for defense / regulated deploy) ───────────
KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
KAMIWAZA_API_KEY=your-kamiwaza-key

# ── OpenAI direct ────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── OpenRouter ───────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...

# ── Any OpenAI-compatible endpoint (Together, Groq, vLLM, Ollama, ...) ──────
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=...

# ── Anthropic (Claude) — chat only; ANCHOR also needs embeddings ────────────
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...

# Optional model overrides
# LLM_PRIMARY_MODEL=gpt-4o-mini
# LLM_FALLBACK_MODELS=gpt-4o-mini,gpt-4o
