# GUARDRAIL — env vars (mirrors repo-root .env)
# Pick ONE provider:

# Kamiwaza on-prem (recommended for IL5/IL6)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/v1
# KAMIWAZA_API_KEY=...

# OpenAI direct
# OPENAI_API_KEY=...

# Model overrides (optional)
# LLM_PRIMARY_MODEL=gpt-5.4-mini
# LLM_HERO_MODEL=gpt-5.4
