# HUB env example.
# The shared client picks the first provider whose vars are set.

# Option A — Kamiwaza on-prem (preferred for the demo story):
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=…

# Option B — OpenAI direct (used at the hackathon):
# OPENAI_API_KEY=sk-…
# OPENAI_PRIMARY_MODEL=gpt-5.4-mini
# OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,gpt-4o

# Real-data swap (optional):
# REAL_DATA_PATH=/path/to/extracted/ntad/shapefiles
