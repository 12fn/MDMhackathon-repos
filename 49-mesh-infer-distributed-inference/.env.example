# MESH-INFER — per-node Kamiwaza endpoint pattern
# When these are set, the router dispatches each step to the matching node.
# Until then, all steps run through the shared kamiwaza_client (single endpoint
# simulation) and the mesh is visualized as if routing happened.

# Edge node — Jetson Orin at MEU SOC. Vision + low-latency / DDIL-friendly.
KAMIWAZA_EDGE_URL=https://edge.meu-soc.local/api/v1
KAMIWAZA_EDGE_API_KEY=replace-me
KAMIWAZA_EDGE_MODEL=qwen2.5-vl-7b

# Rear depot node — Lambda DGX at MCB Quantico. vLLM tensor-parallel.
KAMIWAZA_REAR_URL=https://depot.quantico.usmc.mil/api/v1
KAMIWAZA_REAR_API_KEY=replace-me
KAMIWAZA_REAR_MODEL=llama-3.3-70b-fp8

# SCIF node — MARFORPAC HQ, behind JWICS, airgapped from commercial internet.
KAMIWAZA_SCIF_URL=https://scif.marforpac.smil.mil/api/v1
KAMIWAZA_SCIF_API_KEY=replace-me
KAMIWAZA_SCIF_MODEL=mixtral-8x22b
KAMIWAZA_SCIF_VL_MODEL=qwen2.5-vl-72b

# Fallback (used by shared/kamiwaza_client when the per-node URLs above are unset)
OPENAI_API_KEY=
OPENAI_PRIMARY_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini
