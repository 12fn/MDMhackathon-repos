# FED-RAG — env example
#
# The shared client auto-detects in this order:
#   KAMIWAZA_BASE_URL > OPENROUTER_API_KEY > LLM_BASE_URL > ANTHROPIC_API_KEY > OPENAI_API_KEY
#
# FED-RAG also reads PER-SILO Kamiwaza Inference Mesh endpoints. These are
# surfaced in the UI to prove the federation deployment shape:
KAMIWAZA_SILO_ALBANY_URL=https://kamiwaza-albany.usmc.mil/api/v1
KAMIWAZA_SILO_PENDLETON_URL=https://kamiwaza-pendleton.usmc.mil/api/v1
KAMIWAZA_SILO_PHILLY_URL=https://kamiwaza-philly.dla.mil/api/v1

# --- Option 1: Kamiwaza on-prem (target deployment, central node)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=your-kamiwaza-key

# --- Option 2: OpenAI direct (default for hackathon dev)
OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,gpt-4o

# --- Option 3: Anthropic (chat) + OpenAI (embeddings)
# ANTHROPIC_API_KEY=sk-ant-...
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...
