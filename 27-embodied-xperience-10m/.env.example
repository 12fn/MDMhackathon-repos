# EMBODIED — egocentric Marine training simulator
# Copy to .env and fill in values, OR rely on the repo-root .env (auto-loaded by shared/kamiwaza_client).

# -------- Provider selection (any ONE of these) --------
# Kamiwaza on-prem (recommended for the demo):
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=...

# OpenAI direct (used during dev):
# OPENAI_API_KEY=sk-...

# Anthropic (vision works for image_url; no native JSON mode):
# ANTHROPIC_API_KEY=...

# -------- Model overrides (optional) --------
# Hero multimodal model — must be vision-capable on the active provider.
# EMBODIED_HERO_MODEL=gpt-4o
# Pre-cache + AAR model (cheaper, text-only):
# EMBODIED_PRECACHE_MODEL=gpt-4o-mini
# EMBODIED_AAR_MODEL=gpt-4o-mini

# Timeouts (seconds) — see AGENT_BRIEF_V2 §B
# EMBODIED_EVAL_TIMEOUT=25
# EMBODIED_AAR_TIMEOUT=35

# -------- Real-data plug-in --------
# Point at a curated Xperience-10M subset to swap in real frames + scenarios.
# REAL_DATA_PATH=/path/to/xperience10m_subset/
