# TRAVELOG — provider env vars (see shared/kamiwaza_client.py)
# The shared client auto-detects in this order:
#   KAMIWAZA_BASE_URL → OPENROUTER_API_KEY → LLM_BASE_URL+LLM_API_KEY
#   → ANTHROPIC_API_KEY → OPENAI_API_KEY

# On-prem (preferred for the demo cold-open beat):
# KAMIWAZA_BASE_URL=https://kamiwaza.<installation>.usmc.mil
# KAMIWAZA_API_KEY=replace-me

# Cloud fallback (used when running outside the wire):
# OPENAI_API_KEY=sk-...

# Models (Kamiwaza maps these to whatever's deployed):
LLM_PRIMARY_MODEL=gpt-5.4-mini
LLM_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini
OPENAI_HERO_MODEL=gpt-5.4

# Real-data plug-in (load_real.py):
# REAL_DTS_PATH=
# REAL_ASSETS_PATH=
# REAL_BTS_NODES=
# REAL_BTS_EDGES=
# REAL_LADE_PATH=
