# OPENGATE — env example
#
# Pick one provider. The shared client auto-detects in this order:
#   KAMIWAZA_BASE_URL > OPENROUTER_API_KEY > LLM_BASE_URL > ANTHROPIC_API_KEY > OPENAI_API_KEY
#
# OPENGATE needs embeddings. If you pick Anthropic, also set EMBEDDING_BASE_URL +
# EMBEDDING_API_KEY (any OpenAI-compat endpoint) so the embed() call has somewhere
# to land.

# --- Option 1: Kamiwaza on-prem (target deployment)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=your-kamiwaza-key

# --- Option 2: OpenAI direct (default for hackathon dev)
OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,gpt-4o

# --- Option 3: Anthropic (chat) + OpenAI (embeddings)
# ANTHROPIC_API_KEY=sk-ant-...
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...
