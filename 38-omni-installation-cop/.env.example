# OMNI ENV — copy to .env at the repo root or this app's dir.

# Provider — defaults to KAMIWAZA_BASE_URL if set, else OPENAI_API_KEY.
# OPENAI_API_KEY=sk-...
# KAMIWAZA_BASE_URL=https://kamiwaza-on-prem.local/v1
# KAMIWAZA_API_KEY=kamiwaza

# Model selection (passed straight through to the active provider).
LLM_PRIMARY_MODEL=gpt-5.4-mini
LLM_FALLBACK_MODELS=gpt-5.4-mini,gpt-5.4

# OMNI ports (split FE/BE).
OMNI_FRONTEND_PORT=3038
OMNI_BACKEND_PORT=8038
OMNI_BACKEND_URL=http://localhost:8038

# Synth-time precompute control.
# Set to 0 to skip the live LLM precompute and only seed the deterministic
# baseline into data/cached_briefs.json.
OMNI_PRECOMPUTE_LIVE=1

# Wipe audit log on backend startup so the demo always starts clean.
OMNI_RESET_AUDIT_ON_START=1

# Real-data plug-in (see data/load_real.py for required schemas).
# OMNI_HIFLD_PATH=/path/to/hifld_export.geojson
# OMNI_EARTHDATA_PATH=/path/to/merra2_subset.nc4
# OMNI_FIRMS_CSV=/path/to/MODIS_C6_Global_24h.csv
# OMNI_GCSS_PATH=/path/to/gcss_mc_export.csv
# OMNI_RF_PATH=/path/to/rf_traces.parquet
# OMNI_DRONE_RF_PATH=/path/to/drone_rf_capture.csv
