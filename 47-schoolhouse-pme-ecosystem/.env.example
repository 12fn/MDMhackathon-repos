# SCHOOLHOUSE — env example
# Copy to .env at the repo root (the multi-provider client auto-loads it).

# OpenAI direct
OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODELS=gpt-4o-mini,gpt-4o

# Or Kamiwaza on-prem (auto-detected when both vars are present)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=<from /run/secrets/kw>

# Or any OpenAI-compatible endpoint (vLLM, Together.ai, OpenRouter, …)
# LLM_BASE_URL=https://...
# LLM_API_KEY=...

# Hero / vision model overrides (server-side mapped by Kamiwaza)
SCHOOLHOUSE_VISION_MODEL=gpt-4o

# Real-data swap paths (see data/load_real.py)
# REAL_MBZ_PATH=/path/to/moodle_export.mbz
# REAL_ASSIGNMENTS_PATH=/path/to/assignments_dir
# REAL_X10M_PATH=/path/to/xperience10m_subset
# REAL_MOD_PATH=/path/to/military_object_detection
