# ─────────────────────────────────────────────────────────────────────────────
# Pick ONE provider. The shared client auto-detects from env vars
# (priority: Kamiwaza → OpenRouter → custom OpenAI-compat → Anthropic → OpenAI).
# Override the auto-pick with LLM_PROVIDER=<name>.
# ─────────────────────────────────────────────────────────────────────────────

# ── Option 1: Kamiwaza on-prem (recommended for defense/regulated deploy) ────
# OpenAI-compatible surface; weights deployed inside your enclave.
KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
KAMIWAZA_API_KEY=your-kamiwaza-key

# ── Option 2: OpenRouter (cloud, multi-model marketplace) ───────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1   # default

# ── Option 3: Any other OpenAI-compatible endpoint ──────────────────────────
# Together.ai, Groq, Anyscale, Fireworks, vLLM, Ollama, LM Studio, etc.
# LLM_BASE_URL=https://api.together.xyz/v1
# LLM_API_KEY=...

# ── Option 4: Anthropic (Claude) ────────────────────────────────────────────
# Native Messages API. Vision works; tool-calling and JSON-mode are emulated.
# Apps with vision/tools/JSON work better on an OpenAI-compat provider.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ── Option 5: OpenAI direct (cloud fallback for local dev) ──────────────────
# OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────────────
# Model name overrides (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Default primary model name passed to the API. The active provider maps this
# server-side to whatever weights it has deployed (e.g. Kamiwaza maps "gpt-4o-mini"
# to your chosen on-prem model). If your provider exposes models under different
# names, override here.
# LLM_PRIMARY_MODEL=gpt-4o-mini
# LLM_FALLBACK_MODELS=gpt-4o-mini,gpt-4o

# ─────────────────────────────────────────────────────────────────────────────
# Embeddings (only OpenAI-compat providers have native embeddings)
# ─────────────────────────────────────────────────────────────────────────────
# If you're running Anthropic for chat but need embeddings (RAG apps), point
# embeddings at any OpenAI-compatible provider here:
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...
