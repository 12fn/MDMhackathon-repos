# CHAIN — env config (copy to .env at repo root, not here)
# All apps share /Users/finnegannorris/code/hackathonMDM/.env via shared/kamiwaza_client.py
#
# At least one provider must be configured:
KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
KAMIWAZA_API_KEY=...
# OR
OPENAI_API_KEY=sk-...
# OR
ANTHROPIC_API_KEY=sk-ant-...
#
# Models — overridden per-call when needed
LLM_PRIMARY_MODEL=gpt-5.4-mini
LLM_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,gpt-4o
#
# Real-data plug-in
REAL_DATA_DIR=/path/to/real/kaggle/datasets
