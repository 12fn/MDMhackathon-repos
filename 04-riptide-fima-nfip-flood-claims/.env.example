# RIPTIDE env example. Copy values from /Users/finnegannorris/code/hackathonMDM/.env
OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini

# Hero call uses gpt-5.4 (no -mini). Override if unavailable in your account:
RIPTIDE_HERO_MODEL=gpt-5.4

# To swap to Kamiwaza on-prem (no other code change needed):
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=<your-token>

BACKEND_URL=http://localhost:8004
