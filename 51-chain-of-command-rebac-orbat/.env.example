# CHAIN-OF-COMMAND — env vars (mirrors repo-root .env)
# Pick ONE provider:

# Kamiwaza on-prem (recommended for IL5/IL6 — air-gapped ReBAC engine)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/v1
# KAMIWAZA_API_KEY=...

# OpenAI direct (used during hackathon dev)
# OPENAI_API_KEY=...

# Model overrides (optional)
# LLM_PRIMARY_MODEL=gpt-5.4-mini
# LLM_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini

# Real-data ingestion (see data/load_real.py)
# REAL_ORBAT_DIR=/path/to/mol-export
# REAL_KEYCLOAK_EXPORT=/path/to/realm-export.json
# REAL_GCSS_TASK_ORG=/path/to/gcss-mc-task-org.csv
