# Kamiwaza on-prem (preferred posture)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=...

# Real-data swap (optional)
# REAL_DEPOT_CSV=/path/to/gcssmc_depots.csv
# REAL_LSC_CSV=/path/to/logistics-and-supply-chain.csv
