# OMNI-INTEL -- multi-INT fusion app
# Default to OPENAI_API_KEY for the hackathon; the shared client also supports
# Kamiwaza on-prem, OpenRouter, Anthropic, and any OpenAI-compatible endpoint.

OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini

# On-prem swap -- the multi-INT fusion stays in the JWICS-equivalent enclave:
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=...

# Real-data swap paths (see data/load_real.py for required schema per source):
# REAL_AIS_PATH=/data/ais_aug2024.csv
# REAL_ASAM_PATH=/data/asam.geojson
# REAL_MILOBJ_PATH=/data/milobj_coco.json
# REAL_HITUAV_PATH=/data/hituav/labels/
# REAL_DRONERF_PATH=/data/dronerf.csv
# REAL_WIFIBT_PATH=/data/wifibt.pcap
# REAL_FIRMS_PATH=/data/firms_ukraine.csv
