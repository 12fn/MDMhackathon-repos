# QUEUE — env vars (copy to .env or rely on repo-root .env)

# Active provider (one of):
# OPENAI_API_KEY=sk-...
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=kamiwaza
# OPENROUTER_API_KEY=...
# ANTHROPIC_API_KEY=...

# Real-data plug-in (when you have GCSS-MC depot extracts on disk):
# QUEUE_REAL_DATA_DIR=/path/to/gcss-mc/extracts
