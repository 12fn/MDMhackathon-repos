# AGORA — env example. Copy to .env (or rely on the repo-root .env).

# Primary path: Kamiwaza-deployed model (vLLM / OpenAI-compat surface)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=your-kamiwaza-key

# Fallback: OpenAI direct
# OPENAI_API_KEY=sk-...
# OPENAI_PRIMARY_MODEL=gpt-5.4-mini
# OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini

# Real-data plug-in:
# REAL_DATA_DIR=/path/to/keycloak_export_and_help_corpus
