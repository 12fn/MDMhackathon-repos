# REDLINE — environment overrides

# Pick one provider stack (the shared client autodetects):
#  KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
#  KAMIWAZA_API_KEY=...
#  OPENROUTER_API_KEY=sk-or-...
#  ANTHROPIC_API_KEY=sk-ant-...
#  OPENAI_API_KEY=sk-...

# Models (the shared client falls back through the chain if any fail)
LLM_PRIMARY_MODEL=gpt-5.4-mini
LLM_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,gpt-4o
LLM_HERO_MODEL=gpt-5.4

# Optional: point at a real-data corpus
# REAL_DATA_PATH=/path/to/draft/dir
