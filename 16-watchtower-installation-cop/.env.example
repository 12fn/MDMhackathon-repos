# WATCHTOWER — environment template.
# Copy to /Users/finnegannorris/code/hackathonMDM/.env and fill in.

# --- LLM provider (Kamiwaza on-prem is the recommended default) -------------
# When set, every call routes through your accredited Kamiwaza endpoint.
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=<token>

# --- Fallback for local dev: any OpenAI-compatible endpoint -----------------
# OPENAI_API_KEY=sk-...
# OPENAI_PRIMARY_MODEL=gpt-5.4-mini
# OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini

# --- WATCHTOWER backend ports / wiring --------------------------------------
WATCHTOWER_BACKEND_URL=http://localhost:8016
WATCHTOWER_BACKEND_PORT=8016
# Skip the LLM precompute pass when running data/generate.py (1 = skip)
# WATCHTOWER_PRECOMPUTE_LIVE=0
