# DISPATCH — env config

# OpenAI today (the shared client auto-detects)
OPENAI_API_KEY=sk-...
OPENAI_PRIMARY_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,gpt-4o

# Kamiwaza tomorrow — uncomment to swap to on-prem
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=...

# Real-data plug-in (see data/load_real.py)
# DISPATCH_CALLS_SRC=/srv/ng911/calls.json
# DISPATCH_UNITS_SRC=/srv/cad/units.json

# Service ports
DISPATCH_FRONTEND_PORT=3031
DISPATCH_BACKEND_PORT=8031
DISPATCH_BACKEND_URL=http://localhost:8031
