# STORM-SHIFT — env stub. The repo root .env is auto-loaded by shared/kamiwaza_client.
# Override here to demonstrate the on-prem (Kamiwaza) plug.

# OPENAI_API_KEY=sk-...
# OPENAI_PRIMARY_MODEL=gpt-5.4-mini
# OPENAI_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini

# To run on-prem: storm models stay in your enclave, no cloud egress.
# KAMIWAZA_BASE_URL=https://kamiwaza.local/v1
# KAMIWAZA_API_KEY=...

# Real-data plug-in paths (see data/load_real.py):
