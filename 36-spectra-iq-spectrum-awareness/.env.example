# SPECTRA — Marine FOB / Installation Spectrum Awareness
# Copy to .env (or use the repo-root .env). The shared kamiwaza_client
# auto-detects the active provider in this priority:
#   1. KAMIWAZA_BASE_URL    (Kamiwaza on-prem)
#   2. OPENROUTER_API_KEY   (OpenRouter)
#   3. LLM_BASE_URL + LLM_API_KEY (any OpenAI-compat)
#   4. ANTHROPIC_API_KEY    (Anthropic)
#   5. OPENAI_API_KEY       (OpenAI direct)

# === On-prem Kamiwaza ===
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=...

# === OpenAI direct (default for the demo) ===
OPENAI_API_KEY=sk-...

# === Real-data ingestion (optional) ===
# Point to a directory of .npy complex64 I/Q files plus a metadata CSV.
# REAL_DATA_PATH=/path/to/nist_iq/captures

# === Model overrides (optional) ===
# LLM_PRIMARY_MODEL=gpt-5.4-mini
# LLM_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,gpt-4o
# SPECTRA_VISION_MODEL=gpt-4o
