# CADENCE — Adaptive PME Tutor environment template
# Copy to ../../.env or to ./.env, populate, then `streamlit run src/app.py`.

# Pick ONE of:
# (A) Kamiwaza on-prem (production target — recommended for the demo)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=...
# (B) OpenRouter
# OPENROUTER_API_KEY=...
# (C) Anthropic
# ANTHROPIC_API_KEY=...
# (D) OpenAI direct (default for local dev / hackathon)
OPENAI_API_KEY=

# Model chain (kept in env so swap is one-line)
LLM_PRIMARY_MODEL=gpt-5.4-mini
LLM_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,gpt-4o
CADENCE_HERO_MODEL=gpt-5.4

# Real-data plug-in (see data/load_real.py docstring)
# Drop .mbz Moodle 4.5+ exports here:
# REAL_LMS_EXPORT_DIR=/abs/path/to/lms_exports
# Drop "Student Written Assignment Examples" bundle here:
# REAL_STUDENT_ARTIFACTS_DIR=/abs/path/to/student_artifacts
