# GUARDIAN — env example. The shared client auto-detects provider precedence:
#   KAMIWAZA_BASE_URL → OPENROUTER_API_KEY → LLM_BASE_URL → ANTHROPIC_API_KEY → OPENAI_API_KEY

# Kamiwaza on-prem (preferred for production)
# KAMIWAZA_BASE_URL=https://kamiwaza.local/api/v1
# KAMIWAZA_API_KEY=...

# OpenAI (cloud fallback for hackathon)
OPENAI_API_KEY=sk-...

# Model selection
LLM_PRIMARY_MODEL=gpt-5.4-mini
LLM_FALLBACK_MODELS=gpt-5-mini,gpt-4o-mini,gpt-4o

# Optional: real-data swap target for data/load_real.py
# REAL_DATA_PATH=/path/to/intercepts.jsonl
